# ── REQUIRED ─────────────────────────────────────────────────────────────────
# Supabase Postgres (Session Pooler — URL-encode password special chars: $ → %24, & → %26)
DATABASE_URL=postgresql+asyncpg://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:5432/postgres

# ── SECURITY ──────────────────────────────────────────────────────────────────
# Shared secret between Next.js proxy and FastAPI backend.
# Generate with: openssl rand -hex 32
# Set the SAME value in both Vercel env vars and Render/Fly.io env vars.
# Leave empty in local dev — backend skips the check when unset.
INTERNAL_API_SECRET=

# Exact frontend URL for CORS (e.g. https://your-app.vercel.app)
# Leave empty in local dev — localhost origins are always allowed.
FRONTEND_URL=

# ── OPTIONAL: configure the rest via Settings UI after first launch ───────────

# Redis — only needed if Telegram bot is enabled
REDIS_URL=redis://localhost:6379

# LLM Providers — can be set via Settings UI instead of here
OLLAMA_URL=http://localhost:11434
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Z.ai / GLM-5.1 (Cloud API)
Z_AI_API_KEY=
Z_AI_BASE_URL=https://api.z.ai/v1

# GLM-5.1 (Local Inference via vLLM/llama.cpp)
GLM51_LOCAL_URL=

# Telegram bot — can be set via Settings UI instead
TELEGRAM_BOT_TOKEN=

# Tools — can be set via Settings UI instead
OPENWEATHERMAP_API_KEY=

# App
DEBUG=False
ENVIRONMENT=development

# ── LANGFUSE (LLM Observability) ──────────────────────────────────────────────
# Option A: Langfuse Cloud (https://cloud.langfuse.com)
#   Set only these 3 — remove or comment out the self-hosted block below:
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# Option B: Self-hosted via docker-compose (uses Supabase — no separate DB container)
#   Use Supabase Session Pooler URL (port 5432, NOT 6543) + sslmode=require
#   Get it from: Supabase Dashboard → Project Settings → Database → Connection Pooling → Session mode
LANGFUSE_DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require
LANGFUSE_NEXTAUTH_SECRET=change-me-32-chars-minimum!!
LANGFUSE_SALT=change-me-salt-value
# LANGFUSE_PUBLIC_KEY=pk-lf-...   ← fill after first docker compose up + Langfuse signup
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://langfuse:3000
