# Database (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJhbGc...
DATABASE_URL=postgresql://postgres:password@your-project.supabase.co:5432/postgres

# Redis (Local)
REDIS_URL=redis://localhost:6379

# LLM Providers
OLLAMA_URL=http://localhost:11434
OPENROUTER_API_KEY=sk-or-...

# Z.ai / GLM-5.1 Cloud API
# Get API key from https://z.ai
Z_AI_API_KEY=
Z_AI_BASE_URL=https://api.z.ai/v1

# GLM-5.1 Local Inference (vLLM or llama.cpp)
# Set this to enable local GLM-5.1 inference (e.g., http://localhost:8000/v1)
# Requires running vLLM or llama.cpp server locally
# See: https://docs.vllm.ai/projects/recipes/en/latest/GLM/GLM5.html
GLM51_LOCAL_URL=

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Tools
OPENWEATHERMAP_API_KEY=your_api_key_here

# App Settings
DEBUG=False
ENVIRONMENT=development
