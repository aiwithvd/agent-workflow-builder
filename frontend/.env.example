# ── Local development ─────────────────────────────────────────────────────────
# Server-side proxy target (never sent to the browser)
BACKEND_URL=http://localhost:8000

# WebSocket — direct browser connection (can't be proxied through serverless)
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1

# Shared secret — leave empty locally; set the same value on Vercel + backend
INTERNAL_API_SECRET=

# ── Vercel production ─────────────────────────────────────────────────────────
# BACKEND_URL=https://your-backend.onrender.com
# NEXT_PUBLIC_WS_URL=wss://your-backend.onrender.com/api/v1
# INTERNAL_API_SECRET=<same 32-char secret as on backend>
